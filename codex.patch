+
+    function resetPreview() {
+        if (activeObjectUrl) {
+            URL.revokeObjectURL(activeObjectUrl);
+            activeObjectUrl = null;
+        }
+        preview.textContent = '📷';
+        preview.classList.remove('photo-placeholder--image');
